# Local-only secrets — gitignored. Do NOT commit.
# Copy template structure from .env.example.

# ── Email (contact form) ─────────────────────────────────────────
EMAIL_USER=codemindsdigital@gmail.com
EMAIL_PASS=your-app-password

# ── Site URL ─────────────────────────────────────────────────────
NEXT_PUBLIC_SITE_URL=https://codeminds.digital

# ── Appwrite ─────────────────────────────────────────────────────
NEXT_PUBLIC_APPWRITE_PROJECT_ID=69f17059001f2290328e
NEXT_PUBLIC_APPWRITE_PROJECT_NAME=cmd-website
NEXT_PUBLIC_APPWRITE_ENDPOINT=https://sgp.cloud.appwrite.io/v1
NEXT_PUBLIC_APPWRITE_DATABASE_ID=cmd_website_db

# Server-only: never prefix with NEXT_PUBLIC_, never commit.
# Rotate after Phase A0 lands — the previous value of this key was
# accidentally committed in .env.example and is in git history.
APPWRITE_API_KEY=standard_d9f9daf3ba4af1aed6bf07fe89ad03c7f477a04e023c0d7a546af1ade264def4a84c5a572903f0fd94e3b61ccc85cf1057ec3cfaa255f46cd1557d1091b7e56b0d810beb54fb99fce35316f4e0b83041dd7e92d05cf574d93a2c4506591189455291bd3949c050d4b29bc4d44606bf707580a1d242d27bb2cc434ffce6ff1682

# Webhook secret for /api/revalidate — Appwrite Function will sign
# requests with this; the route verifies the HMAC before invalidating.
APPWRITE_WEBHOOK_SECRET=8ebaccc88986827eac68fd1154efae16c42e81d84a8370cb10db53b2f9b145c7

# ── Admin route protection ───────────────────────────────────────
# Also used as Bearer token for /api/cron/publish-scheduled.
ADMIN_API_SECRET=codeminds-digital-admin-secret-2026

# ── Slack webhook for publish notifications (optional) ───────────
# Leave blank to disable. Set a Slack Incoming Webhook URL to enable.
SLACK_PUBLISH_WEBHOOK=
